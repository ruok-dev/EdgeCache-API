# ============================================================
# EdgeCache API - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# ============================================================

# --- Server ---
NODE_ENV=development
PORT=3000
API_VERSION=v1

# --- Cache ---
# Default TTL for cache entries (in seconds)
CACHE_DEFAULT_TTL=300
# Maximum number of in-memory cache entries
CACHE_MAX_MEMORY_ENTRIES=10000
# Maximum memory usage (in MB) before LRU eviction
CACHE_MAX_MEMORY_MB=512

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0
REDIS_KEY_PREFIX=edgecache:
# Connection pool size
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY_MS=1000
REDIS_CONNECT_TIMEOUT_MS=5000
REDIS_COMMAND_TIMEOUT_MS=3000

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# --- Logging ---
LOG_LEVEL=info
# Options: pretty (human-readable) | json (structured for production)
LOG_FORMAT=pretty
LOG_INCLUDE_TRACE=false

# --- Proxy / Upstream ---
# Comma-separated list of allowed upstream hosts
UPSTREAM_ALLOWED_HOSTS=api.example.com,api2.example.com
UPSTREAM_TIMEOUT_MS=10000
UPSTREAM_MAX_REDIRECTS=5

# --- Security ---
# Secret for signing internal tokens (change this!)
API_SECRET=change_me_to_a_strong_random_secret_at_least_32_chars
# CORS allowed origins (comma-separated, use * for all)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# --- Metrics ---
METRICS_ENABLED=true
METRICS_ENDPOINT=/metrics
